<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="350" prefWidth="400" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.mygroup.isfilms.controller.FilterController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>
    <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Фильтрация фильмов" />
    <Separator />
    <Label text="Название фильма" />
    <TextField fx:id="titleField" promptText="Введите название" />
    <Label text="Год выпуска" />
    <HBox spacing="10">
        <TextField fx:id="yearFromField" promptText="От (например: 1990)" HBox.hgrow="ALWAYS" />
        <TextField fx:id="yearToField" promptText="До (например: 2020)" HBox.hgrow="ALWAYS" />
    </HBox>
    <Label text="Жанр" />
    <ComboBox fx:id="genreCombo" promptText="Выберите жанр" />
    <Label text="Страна" />
    <ComboBox fx:id="countryCombo" promptText="Выберите страну" />
    <Label text="Рейтинг" />
    <HBox spacing="10">
        <Slider fx:id="ratingFromSlider" blockIncrement="0.5" majorTickUnit="2" max="10" min="0" showTickLabels="true" HBox.hgrow="ALWAYS" />
        <Slider fx:id="ratingToSlider" blockIncrement="0.5" majorTickUnit="2" max="10" min="0" showTickLabels="true" value="10.0" HBox.hgrow="ALWAYS" />
    </HBox>
    <HBox spacing="10">
        <Label fx:id="ratingFromLabel" text="от 0.0" />
        <Label fx:id="ratingToLabel" text="до 10.0" />
    </HBox>
    <Separator />
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#onReset" text="Сбросить" />
        <Button onAction="#onSearch" text="Поиск" />
        <Button onAction="#onCancel" text="Отмена" />
    </HBox>

</VBox>
