<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<VBox  xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ru.mygroup.isfilms.MainController"
       spacing="10" prefWidth="500" prefHeight="400">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Label text="Мои подборки" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <TextField fx:id="collectionNameField" promptText="Название подборки" HBox.hgrow="ALWAYS"/>
        <Button text="Создать" onAction="#onCreateCollection"/>
    </HBox>

    <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
        <ListView fx:id="collectionsList"/>
        <VBox spacing="10">
            <Label text="Фильмы в подборке:"/>
            <ListView fx:id="moviesInCollectionList" VBox.vgrow="ALWAYS"/>
            <HBox spacing="10">
                <Button text="Удалить фильм" onAction="#onRemoveMovie"/>
                <Button text="Удалить подборку" onAction="#onDeleteCollection"/>
            </HBox>
        </VBox>
    </SplitPane>

    <Button text="Добавить фильм в подборку" onAction="#onAddMovie"/>

</VBox >
