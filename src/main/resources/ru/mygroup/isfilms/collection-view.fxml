<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400" prefWidth="500" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.mygroup.isfilms.controller.CollectionController">

    <padding>
        <Insets bottom="10" left="10" right="10" top="10" />
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Мои подборки" />

    <HBox spacing="10">
        <TextField fx:id="collectionNameField" promptText="Название подборки" HBox.hgrow="ALWAYS" />
        <Button onAction="#onCreateCollection" text="Создать" />
    </HBox>

    <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
        <ListView fx:id="collectionsList" />
        <VBox spacing="10">
            <Label text="Фильмы в подборке:" />
            <ListView fx:id="moviesInCollectionList" VBox.vgrow="ALWAYS" />
            <HBox spacing="10">
                <Button onAction="#onRemoveMovie" text="Удалить фильм" />
                <Button onAction="#onDeleteCollection" text="Удалить подборку" />
            </HBox>
        </VBox>
    </SplitPane>

    <Button onAction="#onAddMovie" text="Добавить фильм в подборку" />

</VBox>
